# fuentes.env — URLs de fuentes externas del ETL de SIPI
# Editar aquí si alguna fuente cambia de ubicación.
# Este fichero se carga automáticamente junto con .env mediante config.py.
#
# NO incluir credenciales aquí — van en .env

# ── INE ───────────────────────────────────────────────────────────────────────
# Nomenclátor de municipios: sustituir {yy} por el año de 2 dígitos (ej. 26)
INE_NOMENCLATOR_URL=https://www.ine.es/daco/daco42/codmun/{yy}codmun.xlsx

# ── DIR3 ──────────────────────────────────────────────────────────────────────
# Directorio Común de Unidades Orgánicas y Oficinas (PAe)
DIR3_ZIP_URL=https://administracionelectronica.gob.es/ctt/resources/Soluciones/238/Descargas/Dir3_Unidades_Organismos_v7.zip

# ── Registradores de la Propiedad (CORPME) ────────────────────────────────────
# Directorio por provincia: sustituir {provincia} por el slug (ej. madrid)
REGISTRADORES_DIRECTORIO_URL=https://www.registradores.org/directorio/-/registros/propiedad/{provincia}

# ── Colegios Notariales (Ministerio de Exteriores) ────────────────────────────
COLEGIOS_NOTARIALES_PDF_URL=https://www.exteriores.gob.es/es/ServiciosAlCiudadano/Documents/Legalizaciones/Listado%20Colegios%20Notariales%20de%20Espa%C3%B1a.pdf

# ── OSM Overpass ─────────────────────────────────────────────────────────────
OVERPASS_URL=https://overpass-api.de/api/interpreter
