# SIPI staging — contenido del secret `SIPI_ENV_PRODUCTION` (Actions) o del
# .env.production en el servidor. Copia, rellena los CHANGEME y NO lo commitees.
#
# Fase 1 (BD + receptor ETL). Cuando se añadan API+frontend se ampliará.

# --- Dominios / Traefik (mismas variables que SIGA y que el compose dev) ---
APP_PREFIX=sipi
# Host único de SIPI. El webhook del ETL se expone como path /odm de este host
# (Traefik enruta por path); la BD y la API quedan internas.
APP_DOMAIN=sipi.staging.europalaica.org
# Nombre del certresolver de Let's Encrypt configurado en tu Traefik:
TRAEFIK_CERTRESOLVER=letsencrypt

# --- PostgreSQL (servicio db) ---
POSTGRES_USER=sipi
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=sipi

# --- Conexión a la BD (async; sipi-core deriva el DSN sync para alembic) ---
DATABASE_URL=postgresql+asyncpg://sipi:CHANGEME@db:5432/sipi

# --- Esquema (Esquema B: todo en `sipi`) ---
APP_SCHEMA=sipi
GIS_SCHEMA=sipi
DEFAULT_SCHEMA=sipi
DATABASE_SCHEMA=sipi

# --- Enganche con ODM ---
# URL PÚBLICA/alcanzable de ODM (no una IP interna de docker como 172.18.0.3,
# salvo que el ETL comparta esa red docker). El ETL acepta ODM_BASE_URL o, si no,
# ODMGR_URL (el nombre canónico del .env compartido de SIPI).
ODM_BASE_URL=https://<host-odm>
ODM_WEBHOOK_SECRET=CHANGEME          # mismo valor que el webhook_secret del Subscriber en ODM
ODM_APP_TOKEN=CHANGEME               # token Bearer de la aplicación SIPI en ODM (para bootstrap_suscripciones)

# --- Imagen ---
IMAGE_TAG=latest
