# === Monorepo SIPI: ignores comunes (cada subproyecto puede añadir los suyos) ===

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Entornos virtuales
.venv/
venv/
env/
ENV/

# Node / frontend
node_modules/
.pnpm-store/
dist-ssr/
*.local

# Variables de entorno (usar los .env.example de cada subproyecto)
.env
.env.*
!.env.example
!.env.*.example

# Temporales / copias / artefactos
*.bak
*.kk
*.log
projecttree.txt

# Editores / SO
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db

# Notebooks
.ipynb_checkpoints/

# Config local de agentes
.claude/settings.local.json
